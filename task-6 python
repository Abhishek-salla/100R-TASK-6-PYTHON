# Part 5: Identity & Membership Operators


a = [1, 2, 3]
b = a
c = [1, 2, 3]

# Identity operators
print("a is b:", a is b)           # True (same object)
print("a is c:", a is c)           # False (different objects with same values)
print("a is not c:", a is not c)   # True

# Membership operators
print("2 in a:", 2 in a)           # True
print("5 not in a:", 5 not in a)   # True

text = "Hello Python"
print("'Python' in text:", "Python" in text)
print("'Java' not in text:", "Java" not in text)
