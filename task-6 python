x += 5   # add and assign
print("After x += 5:", x)

x -= 3   # subtract and assign
print("After x -= 3:", x)

x *= 2   # multiply and assign
print("After x *= 2:", x)

x /= 4   # divide and assign
print("After x /= 4:", x)

x %= 3   # modulus and assign
