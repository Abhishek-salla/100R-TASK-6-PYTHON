# Arithmetic Operators and Special Operators Assignment


# Part 1: Arithmetic Operators


def rectangle_properties(length, width):
    area = length * width          # multiplication
    perimeter = 2 * (length + width)  # addition and multiplication
    print(f"Area: {area}, Perimeter: {perimeter}")

rectangle_properties(10, 5)



# Part 2: Comparison Operators


def compare_numbers(a, b):
    if a > b:
        print(f"{a} is greater than {b}")
    elif a < b:
        print(f"{a} is smaller than {b}")
    elif a == b:
        print(f"{a} is equal to {b}")
    if a != b:
        print(f"{a} is not equal to {b}")
    if a >= b:
        print(f"{a} is greater than or equal to {b}")
    if a <= b:
        print(f"{a} is smaller than or equal to {b}")

compare_numbers(7, 10)
compare_numbers(10, 10)



# Part 3: Logical Operators


def logical_demo(num, text):
    # Check if number is within range
    if num > 0 and num < 100:
        print(f"{num} is between 0 and 100")

    # Check if string matches pattern
    if text == "Python" or text == "python":
        print("String matches 'Python'")

    # Using not
    if not (num < 0):
        print(f"{num} is not negative")

logical_demo(50, "Python")
logical_demo(-5, "Java")



# Part 4: Assignment Operators


